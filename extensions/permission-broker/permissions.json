{
  "roles": {
    "king": {
      "description": "Meta-orchestrator with full unrestricted access to all tools and operations",
      "toolPolicy": "allow-all",
      "canGrant": ["manager", "worker"],
      "canApprove": true,
      "canEscalateTo": null
    },
    "manager": {
      "description": "Pool manager with near-full access. Can approve elevation requests from own workers. Cannot grant capabilities it doesn't have — must escalate to King AI.",
      "toolPolicy": "deny-list",
      "canGrant": ["worker"],
      "canApprove": true,
      "canEscalateTo": "king-ai"
    },
    "worker": {
      "description": "Task executor with restricted access. Must request elevation from manager for shell, cross-agent messaging, unrestricted filesystem, or elevated operations.",
      "toolPolicy": "deny-list",
      "canGrant": [],
      "canApprove": false,
      "canEscalateTo": null
    }
  },

  "toolDenyLists": {
    "king": [],
    "manager": [],
    "worker": [
      "exec",
      "bash",
      "shell",
      "terminal",
      "sessions_send",
      "message_send",
      "broadcast",
      "elevated_exec",
      "sudo"
    ]
  },

  "capabilityDescriptions": {
    "exec": "Execute shell commands (bash, terminal, etc.)",
    "sessions_send": "Send messages to other agents across the system",
    "fs_unrestricted": "Access files outside of own workspace directory",
    "elevated": "Run elevated/sudo operations",
    "web_search": "Search the web",
    "web_fetch": "Fetch content from URLs",
    "broadcast": "Send broadcast messages to all agents"
  },

  "agents": {
    "king-ai":        { "role": "king",    "pool": ["alpha-manager", "beta-manager", "gamma-manager"] },
    "alpha-manager":  { "role": "manager", "pool": ["general-1", "general-2", "general-3", "general-4"], "manager": "king-ai" },
    "beta-manager":   { "role": "manager", "pool": ["coding-1", "coding-2", "coding-3", "coding-4"],   "manager": "king-ai" },
    "gamma-manager":  { "role": "manager", "pool": ["agentic-1", "agentic-2", "agentic-3", "agentic-4"], "manager": "king-ai" },
    "coding-1":       { "role": "worker", "manager": "beta-manager",  "specialty": "Python" },
    "coding-2":       { "role": "worker", "manager": "beta-manager",  "specialty": "JavaScript/TypeScript" },
    "coding-3":       { "role": "worker", "manager": "beta-manager",  "specialty": "Bash/Infrastructure" },
    "coding-4":       { "role": "worker", "manager": "beta-manager",  "specialty": "Testing/QA" },
    "agentic-1":      { "role": "worker", "manager": "gamma-manager", "specialty": "Web Search" },
    "agentic-2":      { "role": "worker", "manager": "gamma-manager", "specialty": "Document Analysis" },
    "agentic-3":      { "role": "worker", "manager": "gamma-manager", "specialty": "Data Synthesis" },
    "agentic-4":      { "role": "worker", "manager": "gamma-manager", "specialty": "Fact-Checking" },
    "general-1":      { "role": "worker", "manager": "alpha-manager", "specialty": "Writing/Prose" },
    "general-2":      { "role": "worker", "manager": "alpha-manager", "specialty": "Summarization" },
    "general-3":      { "role": "worker", "manager": "alpha-manager", "specialty": "Q&A/Helpdesk" },
    "general-4":      { "role": "worker", "manager": "alpha-manager", "specialty": "Mac Automation" }
  },

  "agentPorts": {
    "king-ai": 18789,
    "alpha-manager": 18800,
    "beta-manager": 18801,
    "gamma-manager": 18802,
    "coding-1": 18803,
    "coding-2": 18804,
    "coding-3": 18805,
    "coding-4": 18806,
    "agentic-1": 18807,
    "agentic-2": 18808,
    "agentic-3": 18809,
    "agentic-4": 18810,
    "general-1": 18811,
    "general-2": 18812,
    "general-3": 18813,
    "general-4": 18814
  },

  "filesystemPolicy": {
    "worker": {
      "mode": "workspace-only",
      "description": "Workers can only access files within their own agent directory and /tmp",
      "additionalAllowedPaths": ["/tmp"]
    },
    "manager": {
      "mode": "unrestricted",
      "description": "Managers have full filesystem access"
    },
    "king": {
      "mode": "unrestricted",
      "description": "King has full filesystem access"
    }
  },

  "sessionPolicy": {
    "worker": "own",
    "manager": "all",
    "king": "all"
  },

  "messagingPolicy": {
    "worker": {
      "canInitiate": false,
      "canReplyTo": "manager-only",
      "canBroadcast": false,
      "description": "Workers can only respond to their assigned manager. Cannot initiate cross-agent messages or broadcast."
    },
    "manager": {
      "canInitiate": true,
      "canReplyTo": "any",
      "canBroadcast": false,
      "description": "Managers can message their workers and King AI. Cannot broadcast."
    },
    "king": {
      "canInitiate": true,
      "canReplyTo": "any",
      "canBroadcast": true,
      "description": "King has unrestricted messaging capabilities."
    }
  }
}
