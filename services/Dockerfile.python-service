FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates build-essential git tesseract-ocr \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# service files mounted at runtime; this image is shared by all Python services
CMD ["python", "-V"]
