# OpenClaw Army container stack env example
POSTGRES_DB=openclaw_army
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=openclaw
POSTGRES_PORT=5432
REDIS_PORT=6379
POSTGRES_URL=postgresql://openclaw:openclaw@postgres:5432/openclaw_army

# Model provider keys (set real values in your local .env.army)
NVAPI_KIMI_KEY_1=
NVAPI_KIMI_KEY_2=
NVAPI_DEEPSEEK_KEY_1=
NVAPI_GLM5_KEY_1=

# Optional notification settings
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFICATION_EMAIL=
