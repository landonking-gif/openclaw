{
  "gateway": {
    "port": 18800,
    "bind": "loopback",
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "mode": "local"
  },
  "logging": {
    "level": "info",
    "consoleStyle": "pretty"
  },
  "ui": {
    "assistant": {
      "name": "alpha-manager",
      "avatar": "alpha-manager"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "nvidia/moonshotai/kimi-k2.5",
        "fallbacks": [
          "nvidia/meta/llama-3.3-70b-instruct",
          "nvidia/nvidia/llama-3.1-nemotron-70b-instruct"
        ]
      },
      "workspace": "/Users/landonking/openclaw-army/agents/alpha-manager",
      "memorySearch": {
        "enabled": true
      }
    }
  },
  "tools": {
    "profile": "full",
    "sessions": {
      "visibility": "all"
    },
    "message": {
      "allowCrossContextSend": true,
      "crossContext": {
        "allowWithinProvider": true,
        "allowAcrossProviders": true
      },
      "broadcast": {
        "enabled": false
      }
    },
    "elevated": {
      "enabled": true
    },
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "maxResults": 10
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "env": {
    "shellEnv": {
      "enabled": true
    }
  },
  "plugins": {
    "enabled": true,
    "load": {
      "paths": [
        "/Users/landonking/openclaw-army/extensions"
      ]
    },
    "entries": {
      "permission-broker": {
        "enabled": true
      },
      "memory-client": {
        "enabled": true
      },
      "cost-tracker": {
        "enabled": true
      },
      "reasoning-engine": {
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "replace",
    "providers": {
      "nvidia": {
        "baseUrl": "https://integrate.api.nvidia.com/v1/",
        "authHeader": true,
        "models": [
          {
            "id": "moonshotai/kimi-k2.5",
            "name": "Kimi K2.5 (NVIDIA NIM)",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "deepseek-ai/deepseek-r1",
            "name": "DeepSeek R1 (NVIDIA NIM)",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "z-ai/glm-5",
            "name": "GLM-5 (NVIDIA NIM)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    },
    "bedrockDiscovery": {
      "enabled": false
    }
  },
  "auth": {
    "profiles": {
      "nvidia:default": {
        "provider": "nvidia",
        "mode": "api_key"
      }
    }
  }
}
