{
  "gateway": {
    "port": 18802,
    "bind": "loopback",
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "logging": {
    "level": "info",
    "consoleStyle": "pretty"
  },
  "providers": [
    {
      "type": "nim",
      "model": "kimi-k2-5",
      "apiKey": "${NVIDIA_NIM_API_KEY}"
    }
  ],
  "ui": {
    "assistant": {
      "name": "gamma-manager",
      "avatar": "gamma-manager"
    }
  }
}
